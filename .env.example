# OpenAI
OPENAI_API_KEY=

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Telegram Bot (alternative to WhatsApp — no phone number needed)
TELEGRAM_BOT_TOKEN=

# PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost:5432/travel_agent

# Redis
REDIS_URL=redis://localhost:6379

# External APIs (Phase 3)
GOOGLE_PLACES_API_KEY=
OPENWEATHER_API_KEY=
AVIATIONSTACK_API_KEY=

# Provider selection
MESSAGING_PROVIDER=console

# LangSmith tracing (optional — enables graph visualization at smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=travel-companion
